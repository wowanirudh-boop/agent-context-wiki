#!/usr/bin/env python3
"""LLM Wiki - local-first knowledge workspace CLI.

Usage:
    llmwiki open <workspace>         Init if needed + serve + open browser
    llmwiki init <workspace>         Create .llmwiki/ + wiki/, index files
    llmwiki serve <workspace>        Start API + web on localhost
    llmwiki mcp <workspace>          Run stdio MCP server (for Claude config)
    llmwiki mcp-config <workspace>   Print claude_desktop_config.json snippet
    llmwiki reindex <workspace>      Force full rebuild of index.db
    llmwiki process <workspace>      Run the v2 placement pipeline
    llmwiki apply-decisions <workspace> [review_file]
    llmwiki lint <workspace> [--json]
    llmwiki eval <workspace> [--json] [--update-baseline]
    llmwiki merge-pages <workspace> <source_page> <target_page>
    llmwiki split-page <workspace> <page> <section> --new-title <title>
    llmwiki rename-page <workspace> <page> <new_title>
    llmwiki coverage <workspace> [source]
    llmwiki hard-delete <workspace> --block-id <block_id>
"""

import argparse
import asyncio
import json
import os
import re
import shutil
import subprocess
import sys
import webbrowser
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
API_DIR = REPO_ROOT / "api"
MCP_DIR = REPO_ROOT / "mcp"
WEB_DIR = REPO_ROOT / "web"

sys.path.insert(0, str(API_DIR))


def _sanitize_name(name: str) -> str:
    slug = name.lower().strip()
    slug = re.sub(r"[^a-z0-9\s-]", "", slug)
    slug = re.sub(r"[\s-]+", "-", slug).strip("-")
    return slug or "wiki"


def cmd_init(workspace: str) -> None:
    ws = Path(workspace).resolve()
    ws.mkdir(parents=True, exist_ok=True)
    (ws / "wiki").mkdir(exist_ok=True)
    (ws / ".llmwiki").mkdir(exist_ok=True)
    (ws / ".llmwiki" / "cache").mkdir(exist_ok=True)

    db_path = ws / ".llmwiki" / "index.db"
    if db_path.exists():
        print(f"Workspace already initialized: {ws}")
        print(f"  index.db: {db_path}")
        return

    # Initialize SQLite
    import sqlite3
    schema_path = REPO_ROOT / "shared" / "sqlite_schema.sql"
    if not schema_path.exists():
        print(f"Error: schema not found at {schema_path}", file=sys.stderr)
        sys.exit(1)

    conn = sqlite3.connect(str(db_path))
    conn.executescript(schema_path.read_text(encoding="utf-8"))

    import uuid
    user_id = str(uuid.uuid5(uuid.NAMESPACE_DNS, "local"))
    ws_id = str(uuid.uuid4())
    ws_name = ws.name

    conn.execute(
        "INSERT INTO workspace (id, name, description, user_id) VALUES (?, ?, '', ?)",
        (ws_id, ws_name, user_id),
    )

    # Scaffold wiki pages
    doc1_id = str(uuid.uuid4())
    conn.execute(
        "INSERT INTO documents (id, user_id, filename, title, path, relative_path, source_kind, "
        "file_type, status, content, tags, version, document_number) "
        "VALUES (?, ?, 'overview.md', 'Overview', '/wiki/', 'wiki/overview.md', 'wiki', "
        "'md', 'ready', ?, '[]', 0, 1)",
        (doc1_id, user_id,
         f"This wiki tracks research on {ws_name}.\n\n## Key Findings\n\nNo sources ingested yet.\n\n## Recent Updates\n\nNo activity yet."),
    )

    doc2_id = str(uuid.uuid4())
    conn.execute(
        "INSERT INTO documents (id, user_id, filename, title, path, relative_path, source_kind, "
        "file_type, status, content, tags, version, document_number) "
        "VALUES (?, ?, 'log.md', 'Log', '/wiki/', 'wiki/log.md', 'wiki', "
        "'md', 'ready', ?, '[]', 0, 2)",
        (doc2_id, user_id, "Chronological record of ingests, queries, and maintenance passes."),
    )

    conn.commit()
    conn.close()
    _apply_acw_migrations(ws)

    # Write actual wiki files
    overview = ws / "wiki" / "overview.md"
    if not overview.exists():
        overview.write_text(
            f"This wiki tracks research on {ws_name}.\n\n"
            "## Key Findings\n\nNo sources ingested yet.\n\n"
            "## Recent Updates\n\nNo activity yet.\n",
            encoding="utf-8",
        )

    log = ws / "wiki" / "log.md"
    if not log.exists():
        log.write_text(
            "Chronological record of ingests, queries, and maintenance passes.\n",
            encoding="utf-8",
        )

    # Index existing files
    _index_existing_files(ws, db_path, user_id, ws_id)
    from core.gitops import ensure_wiki_repo

    ensure_wiki_repo(ws)

    print(f"OK Initialized workspace: {ws}")
    print("  wiki/overview.md - created")
    print("  wiki/log.md - created")
    print("  .llmwiki/index.db - created")


def _index_existing_files(ws: Path, db_path: Path, user_id: str, ws_id: str) -> None:
    """Index existing files in the workspace into SQLite."""
    indexed = asyncio.run(_index_existing_files_async(ws, db_path))

    if indexed > 0:
        print(f"OK Indexed {indexed} existing file(s)")


async def _index_existing_files_async(ws: Path, db_path: Path) -> int:
    import aiosqlite
    from domain.watcher import scan_workspace

    from core.db.migrate import apply_migrations

    async with aiosqlite.connect(db_path) as db:
        await db.execute("PRAGMA journal_mode=WAL")
        await db.execute("PRAGMA foreign_keys=ON")
        await apply_migrations(db)
        return await scan_workspace(db, ws, schedule_processing=False)


def cmd_serve(workspace: str, open_browser: bool = True) -> None:
    ws = Path(workspace).resolve()
    if not (ws / ".llmwiki" / "index.db").exists():
        print(f"Workspace not initialized. Run: llmwiki init {ws}", file=sys.stderr)
        sys.exit(1)

    env = os.environ.copy()
    env["MODE"] = "local"
    env["WORKSPACE_PATH"] = str(ws)
    env["DATABASE_URL"] = ""
    env["APP_URL"] = "http://localhost:3000"
    env["API_URL"] = "http://localhost:8000"

    print(f"Starting LLM Wiki for: {ws}")
    print("  API: http://localhost:8000")
    print("  Web: http://localhost:3000")
    print(f"  MCP: llmwiki mcp-config {ws}")
    print()

    # Start API server
    api_proc = subprocess.Popen(
        [sys.executable, "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"],
        cwd=str(API_DIR),
        env=env,
    )

    # Start web dev server
    web_env = env.copy()
    web_env["NEXT_PUBLIC_MODE"] = "local"
    web_env["NEXT_PUBLIC_API_URL"] = "http://localhost:8000"
    npm = shutil.which("pnpm") or shutil.which("npm")
    if npm is None:
        print(
            "Error: neither pnpm nor npm found on PATH. Install Node.js 20+ "
            "and re-run.",
            file=sys.stderr,
        )
        api_proc.terminate()
        sys.exit(1)
    web_proc = subprocess.Popen(
        [npm, "run", "dev"],
        cwd=str(WEB_DIR),
        env=web_env,
    )

    if open_browser:
        import time
        time.sleep(3)
        webbrowser.open("http://localhost:3000/wikis")

    try:
        api_proc.wait()
    except KeyboardInterrupt:
        print("\nShutting down...")
        api_proc.terminate()
        web_proc.terminate()
        api_proc.wait()
        web_proc.wait()


def cmd_open(workspace: str) -> None:
    ws = Path(workspace).resolve()
    if not (ws / ".llmwiki" / "index.db").exists():
        cmd_init(str(ws))
    cmd_serve(str(ws), open_browser=True)


def cmd_mcp(workspace: str) -> None:
    ws = Path(workspace).resolve()
    if not (ws / ".llmwiki" / "index.db").exists():
        cmd_init(str(ws))

    # local_server lives in mcp/; chdir so `python -m local_server` resolves
    # the module no matter where the CLI was invoked from (Claude Desktop /
    # Code launches this with cwd set to ~ on macOS).
    os.chdir(str(MCP_DIR))
    os.execvp(
        sys.executable,
        [sys.executable, "-m", "local_server", "--workspace", str(ws)],
    )


def cmd_mcp_config(workspace: str, name: str | None = None) -> None:
    ws = Path(workspace).resolve()
    server_name = name or f"llmwiki-{_sanitize_name(ws.name)}"
    llmwiki_path = str(REPO_ROOT / "llmwiki")
    command = llmwiki_path
    args = ["mcp", str(ws)]

    if os.name == "nt":
        command = sys.executable
        args = [llmwiki_path, "mcp", str(ws)]

    config = {
        "mcpServers": {
            server_name: {
                "command": command,
                "args": args,
            }
        }
    }

    print("# Add to claude_desktop_config.json:")
    print(f"# This MCP server is scoped to: {ws}")
    print("# To use another workspace, add another server entry.")
    print()
    print(json.dumps(config, indent=2))


def cmd_reindex(workspace: str) -> None:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        print(f"No index found. Run: llmwiki init {ws}", file=sys.stderr)
        sys.exit(1)

    from core.lock import WorkspaceLock

    with WorkspaceLock(ws, "reindex"):
        _cmd_reindex_locked(ws, db_path)


def _cmd_reindex_locked(ws: Path, db_path: Path) -> None:
    # Drop rebuildable extraction tables; keep documents so source ids remain path-stable.
    import sqlite3
    conn = sqlite3.connect(str(db_path))
    conn.execute("DELETE FROM document_chunks")
    conn.execute("DELETE FROM document_pages")
    conn.commit()

    # Get workspace info
    cursor = conn.execute("SELECT id, user_id FROM workspace LIMIT 1")
    row = cursor.fetchone()
    if not row:
        print("No workspace found in index.", file=sys.stderr)
        sys.exit(1)
    ws_id, user_id = row
    conn.close()

    _index_existing_files(ws, db_path, user_id, ws_id)
    _apply_acw_migrations(ws)
    print(f"OK Reindexed workspace: {ws}")


def cmd_process(workspace: str) -> None:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        cmd_init(str(ws))
    else:
        _apply_acw_migrations(ws)
        _index_existing_files(ws, db_path, "", "")

    from core.pipeline.run import run_processing_run

    result = asyncio.run(run_processing_run(ws))
    print(f"OK Processed workspace: {ws}")
    print(f"  run: {result.run_id}")
    print(f"  pending: {result.stats.get('pending', 0)}")
    print(f"  placed: {result.stats.get('placed', 0)}")
    print(f"  page_writes: {result.stats.get('page_writes', 0)}")


def cmd_apply_decisions(workspace: str, review_file: str | None = None) -> None:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        print(f"No index found. Run: llmwiki init {ws}", file=sys.stderr)
        sys.exit(1)
    _apply_acw_migrations(ws)

    from core.review.apply import apply_decisions

    review_paths = [review_file] if review_file is not None else None
    result = asyncio.run(apply_decisions(ws, review_paths=review_paths))
    print(f"OK Applied decisions: {ws}")
    print(f"  review_files: {len(result.review_files)}")
    print(f"  applied_rows: {result.applied_rows}")
    print(f"  follow_up_rows: {result.follow_up_rows}")
    print(f"  committed: {result.committed}")


def cmd_lint(workspace: str, *, json_output: bool = False) -> int:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        print(f"No index found. Run: llmwiki init {ws}", file=sys.stderr)
        return 1
    _apply_acw_migrations(ws)

    from core.lint.runner import findings_to_json_lines, findings_to_table, has_errors, lint_workspace

    findings = asyncio.run(lint_workspace(ws))
    output = findings_to_json_lines(findings) if json_output else findings_to_table(findings)
    print(output, end="")
    return 1 if has_errors(findings) else 0


def cmd_eval(workspace: str, *, update_baseline: bool = False, json_output: bool = False) -> int:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        print(f"No index found. Run: llmwiki init {ws}", file=sys.stderr)
        return 1

    from core.eval.harness import evaluate_workspace

    result = asyncio.run(evaluate_workspace(ws, update_baseline=update_baseline))
    if json_output:
        print(json.dumps(result.to_dict(), indent=2, sort_keys=True))
    else:
        print(f"Eval score: {result.passed}/{result.total} ({result.score:.3f})")
        if result.baseline_score is not None:
            print(f"Baseline: {result.baseline_score:.3f}")
        if result.regressed:
            print("Regression detected.", file=sys.stderr)
    return 1 if result.regressed else 0


def cmd_merge_pages(workspace: str, source_page: str, target_page: str) -> int:
    ws = Path(workspace).resolve()
    _apply_acw_migrations(ws)
    from core.taxonomy import merge_pages

    result = asyncio.run(merge_pages(ws, source_page, target_page))
    print(f"OK Merged page: {source_page} -> {target_page}")
    print(f"  changed_pages: {len(result.changed_pages)}")
    print(f"  committed: {result.committed}")
    return 0


def cmd_split_page(workspace: str, page: str, section: str, *, new_title: str) -> int:
    ws = Path(workspace).resolve()
    _apply_acw_migrations(ws)
    from core.taxonomy import split_page

    result = asyncio.run(split_page(ws, page, section, new_title=new_title))
    print(f"OK Split page: {page}::{section} -> {new_title}")
    print(f"  changed_pages: {len(result.changed_pages)}")
    print(f"  committed: {result.committed}")
    return 0


def cmd_rename_page(workspace: str, page: str, new_title: str) -> int:
    ws = Path(workspace).resolve()
    _apply_acw_migrations(ws)
    from core.taxonomy import rename_page

    result = asyncio.run(rename_page(ws, page, new_title))
    print(f"OK Renamed page: {page} -> {new_title}")
    print(f"  changed_pages: {len(result.changed_pages)}")
    print(f"  committed: {result.committed}")
    return 0


def cmd_coverage(workspace: str, source: str | None = None) -> None:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        print(f"No index found. Run: llmwiki init {ws}", file=sys.stderr)
        sys.exit(1)
    _apply_acw_migrations(ws)

    import aiosqlite

    from core.coverage import coverage_report_markdown

    async def _run() -> str:
        async with aiosqlite.connect(db_path) as db:
            await db.execute("PRAGMA foreign_keys=ON")
            return await coverage_report_markdown(ws, db, source=source)

    print(asyncio.run(_run()), end="")


def cmd_hard_delete(workspace: str, *, block_id: str) -> None:
    ws = Path(workspace).resolve()
    db_path = ws / ".llmwiki" / "index.db"
    if not db_path.exists():
        print(f"No index found. Run: llmwiki init {ws}", file=sys.stderr)
        sys.exit(1)
    _apply_acw_migrations(ws)

    import aiosqlite

    from core.gitops import commit_hard_delete, hard_delete_block
    from core.lock import WorkspaceLock

    with WorkspaceLock(ws, "hard-delete"):
        async def _run() -> str:
            async with aiosqlite.connect(db_path) as db:
                await db.execute("PRAGMA foreign_keys=ON")
                result = await hard_delete_block(ws, db, block_id)
                return result.warning

        warning = asyncio.run(_run())
        commit = commit_hard_delete(ws, block_id)
    print(f"OK Hard-deleted block: {block_id}")
    print(f"  committed: {commit.committed}")
    print(warning)


def _apply_acw_migrations(ws: Path) -> None:
    from core.db.migrate import migrate_workspace

    asyncio.run(migrate_workspace(ws))


def main():
    parser = argparse.ArgumentParser(
        prog="llmwiki",
        description="LLM Wiki - local-first knowledge workspace",
    )
    sub = parser.add_subparsers(dest="command")

    p_open = sub.add_parser("open", help="Init if needed + serve + open browser")
    p_open.add_argument("workspace", help="Path to workspace folder")

    p_init = sub.add_parser("init", help="Initialize a workspace folder")
    p_init.add_argument("workspace", help="Path to workspace folder")

    p_serve = sub.add_parser("serve", help="Start API + web servers")
    p_serve.add_argument("workspace", help="Path to workspace folder")

    p_mcp = sub.add_parser("mcp", help="Run stdio MCP server")
    p_mcp.add_argument("workspace", help="Path to workspace folder")

    p_config = sub.add_parser("mcp-config", help="Print Claude MCP config snippet")
    p_config.add_argument("workspace", help="Path to workspace folder")
    p_config.add_argument("--name", help="Custom server name")

    p_reindex = sub.add_parser("reindex", help="Force full rebuild of index")
    p_reindex.add_argument("workspace", help="Path to workspace folder")

    p_process = sub.add_parser("process", help="Run the v2 placement pipeline")
    p_process.add_argument("workspace", help="Path to workspace folder")

    p_apply = sub.add_parser("apply-decisions", help="Apply v2 review decisions")
    p_apply.add_argument("workspace", help="Path to workspace folder")
    p_apply.add_argument("review_file", nargs="?", help="Review file path; defaults to unresolved review files")

    p_lint = sub.add_parser("lint", help="Run v2 invariant lint")
    p_lint.add_argument("workspace", help="Path to workspace folder")
    p_lint.add_argument("--json", action="store_true", help="Emit JSON lines")

    p_eval = sub.add_parser("eval", help="Run golden-QA eval over wiki_* read tools")
    p_eval.add_argument("workspace", help="Path to workspace folder")
    p_eval.add_argument("--json", action="store_true", help="Emit JSON")
    p_eval.add_argument("--update-baseline", action="store_true", help="Write current score as eval baseline")

    p_merge = sub.add_parser("merge-pages", help="Merge one wiki page into another")
    p_merge.add_argument("workspace", help="Path to workspace folder")
    p_merge.add_argument("source_page", help="Page title, alias, or path to merge away")
    p_merge.add_argument("target_page", help="Page title, alias, or path to merge into")

    p_split = sub.add_parser("split-page", help="Split one section into a new page")
    p_split.add_argument("workspace", help="Path to workspace folder")
    p_split.add_argument("page", help="Page title, alias, or path")
    p_split.add_argument("section", help="H2 section name to split")
    p_split.add_argument("--new-title", required=True, help="Title for the new page")

    p_rename = sub.add_parser("rename-page", help="Rename a wiki page")
    p_rename.add_argument("workspace", help="Path to workspace folder")
    p_rename.add_argument("page", help="Page title, alias, or path")
    p_rename.add_argument("new_title", help="New page title")

    p_coverage = sub.add_parser("coverage", help="Print ledger-derived Source Coverage")
    p_coverage.add_argument("workspace", help="Path to workspace folder")
    p_coverage.add_argument("source", nargs="?", help="Optional source path, filename, or id")

    p_hard_delete = sub.add_parser("hard-delete", help="Explicitly hard-delete a v2 context block")
    p_hard_delete.add_argument("workspace", help="Path to workspace folder")
    p_hard_delete.add_argument("--block-id", required=True, help="Context block id to hard-delete")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "open":
        cmd_open(args.workspace)
    elif args.command == "init":
        cmd_init(args.workspace)
    elif args.command == "serve":
        cmd_serve(args.workspace)
    elif args.command == "mcp":
        cmd_mcp(args.workspace)
    elif args.command == "mcp-config":
        cmd_mcp_config(args.workspace, getattr(args, "name", None))
    elif args.command == "reindex":
        cmd_reindex(args.workspace)
    elif args.command == "process":
        cmd_process(args.workspace)
    elif args.command == "apply-decisions":
        cmd_apply_decisions(args.workspace, getattr(args, "review_file", None))
    elif args.command == "lint":
        sys.exit(cmd_lint(args.workspace, json_output=getattr(args, "json", False)))
    elif args.command == "eval":
        sys.exit(
            cmd_eval(
                args.workspace,
                update_baseline=getattr(args, "update_baseline", False),
                json_output=getattr(args, "json", False),
            )
        )
    elif args.command == "merge-pages":
        sys.exit(cmd_merge_pages(args.workspace, args.source_page, args.target_page))
    elif args.command == "split-page":
        sys.exit(cmd_split_page(args.workspace, args.page, args.section, new_title=args.new_title))
    elif args.command == "rename-page":
        sys.exit(cmd_rename_page(args.workspace, args.page, args.new_title))
    elif args.command == "coverage":
        cmd_coverage(args.workspace, getattr(args, "source", None))
    elif args.command == "hard-delete":
        cmd_hard_delete(args.workspace, block_id=args.block_id)


if __name__ == "__main__":
    main()
